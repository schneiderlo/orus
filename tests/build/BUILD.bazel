    deps = [
        "//tools:format_lib",
        "//tools/build:acquisition_profile",
        "//tools/build:build_contract",
        "//tools/build:hermeticity_audit_lib",
        "//tools/build:prohibited_path_scan_lib",
        "//tools/coverage:package_gate_lib",
